# Ensure line endings are normalized to LF on checkout/commit
* text=auto

# Specific overrides:
# Ensure Unix shell scripts use LF line endings
/gradlew text eol=lf
*.sh text eol=lf

# Ensure Windows batch scripts use CRLF line endings
*.bat text eol=crlf
*.cmd text eol=crlf

# Keep binary files as-is
*.jar binary
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.gif binary
*.ico binary
